generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PARTICIPANT
  ORGANIZER
  ADMIN
}

enum OrganizerRequestedRole {
  CORE_ORGANIZER
  TECHNICAL_LEAD
  LOGISTICS
  VOLUNTEER
  PR_MARKETING
}

enum OrganizerApprovedRole {
  CORE_ORGANIZER
  TECHNICAL_LEAD
  LOGISTICS
  VOLUNTEER
  PR_MARKETING
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TeamMemberStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TeamStatus {
  DRAFT
  SUBMITTED
}

model User {
  id               String             @id @default(cuid())
  email            String             @unique
  fullName         String
  phone            String?
  passwordHash     String
  role             UserRole           @default(PARTICIPANT)
  createdAt        DateTime           @default(now())
  participant      ParticipantProfile?
  organizerProfile OrganizerProfile?
  leadTeams        Team[]             @relation("TeamLeader")
  memberships      TeamMember[]
  createdTracks    Track[]            @relation("TrackCreator")
  checkinsDone     Checkin[]          @relation("CheckinActor")
  approvedOrgs     OrganizerProfile[] @relation("OrgApprover")
}

model ParticipantProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  registerNumber String   @unique
  graduationYear Int
  college        String
  department     String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OrganizerProfile {
  id             String                 @id @default(cuid())
  userId         String                 @unique
  requestedRole  OrganizerRequestedRole
  approvedRole   OrganizerApprovedRole?
  status         ApprovalStatus         @default(PENDING)
  rejectionReason String?
  reasonForJoining String
  approvedBy     String?
  approvedAt     DateTime?
  createdAt      DateTime               @default(now())
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  approver       User?                  @relation("OrgApprover", fields: [approvedBy], references: [id], onDelete: SetNull)
}

model Track {
  id          String   @id @default(cuid())
  name        String
  description String
  isActive    Boolean  @default(true)
  createdBy   String
  createdAt   DateTime @default(now())
  creator     User     @relation("TrackCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  teams       Team[]
}

model Team {
  id                 String     @id @default(cuid())
  name               String
  code               String     @unique
  leaderId           String
  trackId            String?
  projectName        String?
  projectDescription String?
  techStack          String?
  githubLink         String?
  demoLink           String?
  status             TeamStatus @default(DRAFT)
  qrToken            String?    @unique
  qrCodeUrl          String?
  submittedAt        DateTime?
  createdAt          DateTime   @default(now())
  leader             User       @relation("TeamLeader", fields: [leaderId], references: [id], onDelete: Restrict)
  track              Track?     @relation(fields: [trackId], references: [id], onDelete: SetNull)
  members            TeamMember[]
  checkins           Checkin[]

  @@unique([name, leaderId])
}

model TeamMember {
  id          String           @id @default(cuid())
  teamId       String
  userId       String
  status       TeamMemberStatus @default(PENDING)
  requestedAt  DateTime         @default(now())
  respondedAt  DateTime?
  team         Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model Checkin {
  id          String   @id @default(cuid())
  teamId      String
  checkedInBy String
  checkedInAt DateTime @default(now())
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  actor       User     @relation("CheckinActor", fields: [checkedInBy], references: [id], onDelete: Restrict)
}
